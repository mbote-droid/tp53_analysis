# ============================================================
# TP53 RAG Platform - Environment Configuration
# Copy this to .env and fill in your values
# ============================================================

# --- Inference Mode ---
# 'local' = Ollama on your machine (for final demo)
# 'api'   = Google AI Studio (for testing, no RAM issues)
INFERENCE_MODE=local

# --- Google AI Studio (only needed if INFERENCE_MODE=api) ---
# Get free key at: aistudio.google.com
GOOGLE_API_KEY=your api key
GOOGLE_MODEL=gemma-4-26b-a4b-it

# --- Ollama ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4-lowmem                  # or gemma4:27b for larger model
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=tp53_knowledge_base

# --- NCBI (reuse from your existing pipeline) ---
ENTREZ_EMAIL=youremail@domain.com
NCBI_API_KEY=your_ncbi_api_key_here    # optional but recommended

# --- RAG Settings ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=3
SIMILARITY_THRESHOLD=0.3

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/rag_platform.log

# --- API Server (for n8n integration) ---
API_HOST=0.0.0.0
API_PORT=8000
