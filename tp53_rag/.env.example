# ============================================================
# TP53 RAG Platform - Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- Inference Mode ---
# Controls which LLM backend the platform uses.
# Options:
#   'ollama'   = Gemma 4 e2B via Ollama (recommended, local, offline)
#   'llamacpp' = Gemma 4 via llama.cpp server (lower RAM overhead)
#   'api'      = Google AI Studio API (Gemma 4 26B, for dev/testing only)
#
# Switch between local and API with ONE line change.
# Valid values: ollama | llamacpp | api  (NOT "local")
INFERENCE_MODE=ollama

# Path to GGUF model file (only used when INFERENCE_MODE=llamacpp)
LLAMA_MODEL_PATH=models/gemma-2-2b-it-Q4_K_M.gguf

# llama.cpp server URL (only used when INFERENCE_MODE=llamacpp)
LLAMA_CPP_HOST=http://localhost:8080

# --- Google AI Studio (only needed if INFERENCE_MODE=api) ---
# Free key at: aistudio.google.com
# Uses Gemma 4 26B — better outputs, no RAM needed, requires internet
GOOGLE_API_KEY=your_api_key_here
GOOGLE_MODEL=gemma-4-26b-a4b-it

# --- Ollama (used when INFERENCE_MODE=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4-lowmem          # custom Modelfile: num_ctx 2048, temp 0.0, repeat_penalty 1.15
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=tp53_knowledge_base

# --- NCBI ---
ENTREZ_EMAIL=youremail@domain.com
NCBI_API_KEY=your_ncbi_api_key_here     # optional but improves rate limits

# --- RAG Settings ---
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_RESULTS=3
SIMILARITY_THRESHOLD=0.3

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=./logs/rag_platform.log

# --- API Server (FastAPI — for n8n integration) ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Security ---
# HuggingFace token — needed for UNI pathology model (optional)
# Request access at: huggingface.co/MahmoodLab/UNI
HF_TOKEN=your_hf_token_here
