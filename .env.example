# TP53 RAG Platform — Environment Configuration
# Copy this to .env and fill in your values

# NCBI Entrez API (required for sequence fetching)
ENTREZ_EMAIL=your-email@example.com

# Ollama/llama.cpp Configuration
OLLAMA_HOST=http://localhost:11434
LLAMA_CPP_HOST=http://localhost:8080
MODEL_NAME=gemma-4-e4b-Q4_K_M.gguf

# LLM Parameters
LLM_TEMPERATURE=0.0
LLM_TOP_P=0.95
LLM_MAX_TOKENS=2048
LLM_CONTEXT_WINDOW=8192

# Vector Store (Chroma)
CHROMA_PERSIST_DIR=./tp53_rag/data/chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2

# Data Ingestion (Optional)
NCBI_BATCH_SIZE=10
ENABLE_PUBMED=false
ENABLE_UNIPROT=true

# PII & Security
ENABLE_PII_SCRUBBING=true
HIPAA_AUDIT_LOG=./tp53_rag/logs/hipaa_audit.log

# Logging
LOG_LEVEL=INFO
LOG_FILE=./tp53_rag/logs/tp53_rag.log

# Development
DEBUG=false
OFFLINE_MODE=false
